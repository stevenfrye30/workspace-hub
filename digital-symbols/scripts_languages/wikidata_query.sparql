# Wikidata: every language ↔ script pair
# Run at https://query.wikidata.org/ — download as CSV or JSON
# Expect ~8000+ rows. If it times out, split by script (see split query below).

SELECT ?script ?scriptLabel ?iso15924
       ?language ?languageLabel ?iso639_3 ?iso639_1
       ?nativeName
WHERE {
  # Anything that is (a subclass of) a writing system
  ?script wdt:P31/wdt:P279* wd:Q8192 .

  OPTIONAL { ?script wdt:P506 ?iso15924 . }          # ISO 15924 script code (Latn, Cyrl, …)

  OPTIONAL {
    ?language wdt:P282 ?script .                      # languages that use this script
    OPTIONAL { ?language wdt:P220  ?iso639_3 . }      # ISO 639-3
    OPTIONAL { ?language wdt:P218  ?iso639_1 . }      # ISO 639-1
    OPTIONAL { ?language wdt:P1705 ?nativeName . }    # native label
  }

  SERVICE wikibase:label { bd:serviceParam wikibase:language "en". }
}
ORDER BY ?scriptLabel ?languageLabel

# ---------------------------------------------------------------
# If the full query times out, run it per-script instead, e.g.:
#
# SELECT ?language ?languageLabel ?iso639_3 WHERE {
#   ?language wdt:P282 wd:Q8229 .   # Q8229 = Latin script
#   OPTIONAL { ?language wdt:P220 ?iso639_3 . }
#   SERVICE wikibase:label { bd:serviceParam wikibase:language "en". }
# }
# ---------------------------------------------------------------
